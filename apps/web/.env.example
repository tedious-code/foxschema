# FoxSchema web backend config. Copy to `.env` and fill in what you need.
# Loaded automatically by the backend (apps/web). NEVER commit your real .env.

# --- SSO (optional) ---------------------------------------------------------
# A provider's "Continue with…" button appears only when BOTH its id + secret
# are set. Register this redirect/callback URL with each provider:
#   <app-origin>/api/auth/sso/<provider>/callback
# e.g. http://localhost:5173/api/auth/sso/github/callback  (dev)
# Optionally pin the origin used to build that URL:
# SSO_REDIRECT_BASE=http://localhost:5173

# Google  — https://console.cloud.google.com/apis/credentials (OAuth client)
# SSO_GOOGLE_CLIENT_ID=
# SSO_GOOGLE_CLIENT_SECRET=

# Microsoft / Entra ID — https://entra.microsoft.com (App registrations)
# SSO_MICROSOFT_CLIENT_ID=
# SSO_MICROSOFT_CLIENT_SECRET=
# SSO_MICROSOFT_TENANT=common   # or your tenant id

# GitHub — https://github.com/settings/developers (OAuth Apps) — easiest to test
# SSO_GITHUB_CLIENT_ID=
# SSO_GITHUB_CLIENT_SECRET=

# --- Update check (optional) ------------------------------------------------
# A JSON feed of the latest release: { "version": "1.2.0", "url": "...", "notes": "..." }
# or a GitHub "latest release" API URL.
# UPDATE_FEED_URL=https://api.github.com/repos/<owner>/<repo>/releases/latest
# APP_VERSION=1.0.0

# --- Encryption (dev only; ops sets this in prod) ---------------------------
# APP_ENCRYPTION_KEY=<64 hex chars>
