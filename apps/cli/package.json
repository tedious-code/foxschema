{
  "name": "@foxschema/cli",
  "version": "0.1.45",
  "private": true,
  "type": "module",
  "description": "Fox Schema CLI — database schema diff & migration, in your terminal",
  "bin": {
    "fox": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "fox": "tsx src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "node build.mjs",
    "build:binary": "node build-binary.mjs"
  },
  "dependencies": {
    "@foxschema/core": "*",
    "@foxschema/web": "*",
    "@inquirer/prompts": "^8.5.2",
    "@napi-rs/keyring": "^1.1.6",
    "chalk": "^5.4.1",
    "commander": "^15.0.0",
    "env-paths": "^4.0.0",
    "ink": "^7.1.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "esbuild": "^0.28.1",
    "ink-testing-library": "^4.0.0",
    "postject": "^1.0.0-alpha.6"
  }
}
